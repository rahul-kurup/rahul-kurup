{
  "name": "rahulkurup.com",
  "description": "my portfolio website",
  "author": {
    "name": "Rahul Kurup",
    "email": "rahul.kurup@hotmail.com",
    "url": "https://rahulkurup.com"
  },
  "private": true,
  "version": "0.3.2",
  "scripts": {
    "dev": "next dev --turbopack -p 5544",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "pretty": "prettier --log-level=error --write .",
    "secrets:test": "wrangler versions secret bulk .dev.vars.test -e test",
    "secrets:prod": "wrangler versions secret bulk .dev.vars.prod -e production",
    "deploy:test": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -e test",
    "deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -e production",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "next": "^16.1.7",
    "nookies": "^2.5.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  },
  "overrides": {
    "cookie": "^1.1.1",
    "form-data": ">=4.0.4",
    "js-yaml": "^4.1.1",
    "qs": "^6.14.2",
    "next": "^16.1.6",
    "axios": ">=1.12.0",
    "ajv": ">=6.14.0",
    "minimatch": ">=10.2.3",
    "flatted": "^3.4.1",
    "undici": "^7.24.3",
    "@isaacs/brace-expansion": ">=5.0.1"
  },
  "resolutions": {
    "cookie": "^1.1.1",
    "form-data": ">=4.0.4",
    "js-yaml": "^4.1.1",
    "qs": "^6.14.2",
    "next": "^16.1.6",
    "axios": ">=1.12.0",
    "ajv": ">=6.14.0",
    "minimatch": ">=10.2.3",
    "flatted": "^3.4.1",
    "undici": "^7.24.3",
    "@isaacs/brace-expansion": ">=5.0.1"
  },
  "engines": {
    "node": "24"
  }
}
